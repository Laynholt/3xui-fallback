# =========================================================
# Основной домен.
# Именно его nginx будет обслуживать в server_name.
# Пример:
# SITE_DOMAIN=example.com
# =========================================================
SITE_DOMAIN=example.com


# =========================================================
# ВНЕШНИЕ HTTPS-ПОРТЫ
#
# PANEL_HTTPS_PORT - внешний HTTPS-порт для панели
# SUBS_HTTPS_PORT  - внешний HTTPS-порт для подписок
#
# Примеры:
# https://example.com:9000/panel
# https://example.com:9009/subs/<id>
#
# Важно:
# это именно те порты, которые будет слушать nginx снаружи.
# =========================================================
PANEL_HTTPS_PORT=9000
SUBS_HTTPS_PORT=9009


# =========================================================
# PANEL ACCESS CONTROL
#
# PANEL_ALLOWED_CIDR - сеть или IP, которым разрешен доступ
# к panel proxy на PANEL_HTTPS_PORT.
#
# Безопасный default ниже разрешает доступ только локально.
# Для админской сети укажите свой CIDR, например:
# PANEL_ALLOWED_CIDR=203.0.113.0/24
#
# Если сознательно нужен публичный доступ, используйте:
# PANEL_ALLOWED_CIDR=all
# =========================================================
PANEL_ALLOWED_CIDR=127.0.0.1/32


# =========================================================
# URL PREFIXES
#
# PANEL_PATH_PREFIX - путь, по которому доступна панель
# SUBS_PATH_PREFIX  - базовый путь для подписок
#
# Формат:
# - обязательно с ведущим /
# - без завершающего /
#
# Примеры:
# PANEL_PATH_PREFIX=/my_panel
# SUBS_PATH_PREFIX=/subs
# =========================================================
PANEL_PATH_PREFIX=/my_panel
SUBS_PATH_PREFIX=/subs


# =========================================================
# PANEL BACKEND
#
# PANEL_BACKEND_HOST - адрес backend панели
# PANEL_BACKEND_PORT - внутренний порт backend панели
# PANEL_BACKEND_SCHEME - схема подключения nginx к backend панели
# PANEL_BACKEND_TLS_NAME - имя, по которому nginx проверяет TLS-сертификат
# backend панели, если PANEL_BACKEND_SCHEME=https
# PANEL_BACKEND_SSL_VERIFY - проверять ли TLS-сертификат backend панели
# (on/off), если PANEL_BACKEND_SCHEME=https
#
# Важно:
# backend НЕ должен слушать тот же порт, что и nginx.
# Если nginx снаружи слушает 9000, то backend лучше дать другой,
# например 19000.
#
# Если nginx запущен в network_mode: host, а backend тоже доступен
# на хосте, можно использовать 127.0.0.1.
#
# Если сама панель на 19000 поднимает HTTPS и редиректит HTTP на HTTPS,
# здесь нужно указать https. Иначе снаружи можно получить 307 redirect
# на тот же самый URL панели.
#
# Для https backend сертификат должен быть валиден для PANEL_BACKEND_TLS_NAME
# и доверен CA bundle внутри nginx-контейнера. Если nginx подключается к
# 127.0.0.1, а сертификат backend выпущен на SITE_DOMAIN, укажите здесь
# SITE_DOMAIN.
# =========================================================
PANEL_BACKEND_SCHEME=http
PANEL_BACKEND_HOST=127.0.0.1
PANEL_BACKEND_PORT=19000
PANEL_BACKEND_TLS_NAME=127.0.0.1
PANEL_BACKEND_SSL_VERIFY=off


# =========================================================
# SUBS BACKEND
#
# SUBS_BACKEND_HOST - адрес backend подписок
# SUBS_BACKEND_PORT - внутренний порт backend подписок
# SUBS_BACKEND_SCHEME - схема подключения nginx к backend подписок
# SUBS_BACKEND_TLS_NAME - имя, по которому nginx проверяет TLS-сертификат
# backend подписок, если SUBS_BACKEND_SCHEME=https
# SUBS_BACKEND_SSL_VERIFY - проверять ли TLS-сертификат backend подписок
# (on/off), если SUBS_BACKEND_SCHEME=https
#
# Аналогично:
# если nginx работает в host network, backend подписок на хосте
# тоже можно указывать как 127.0.0.1.
#
# Если backend подписок слушает HTTPS, укажите https.
# Для https backend сертификат должен быть валиден для SUBS_BACKEND_TLS_NAME
# и доверен CA bundle внутри nginx-контейнера.
# =========================================================
SUBS_BACKEND_SCHEME=http
SUBS_BACKEND_HOST=127.0.0.1
SUBS_BACKEND_PORT=19009
SUBS_BACKEND_TLS_NAME=127.0.0.1
SUBS_BACKEND_SSL_VERIFY=off


# =========================================================
# SSL CERTIFICATES
#
# Полные абсолютные пути до сертификатов на хост-машине.
#
# Эти файлы будут примонтированы в контейнер nginx:
# /etc/nginx/certs/fullchain.pem
# /etc/nginx/certs/privkey.pem
#
# Пример:
# SSL_CERT_FULLCHAIN_PATH=/home/user/certs/fullchain.pem
# SSL_CERT_PRIVKEY_PATH=/home/user/certs/privkey.pem
# =========================================================
SSL_CERT_FULLCHAIN_PATH=/home/user/certs/fullchain.pem
SSL_CERT_PRIVKEY_PATH=/home/user/certs/privkey.pem
